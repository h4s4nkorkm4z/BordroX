generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../bordrox.db"
}

model Personnel {
  id         Int      @id @default(autoincrement())
  name       String
  position   String
  phone      String?
  email      String?
  nationalId String?
  iban       String?
  hireDate   String?
  notes      String?
  salary     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}