generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../bordrox.db"
}

model Personnel {
  id             Int      @id @default(autoincrement())
  name           String
  position       String
  department     String?
  phone          String?
  email          String?
  nationalId     String?
  birthDate      String?
  hireDate       String?
  iban           String?
  address        String?
  emergencyName  String?
  emergencyPhone String?
  notes          String?
  photo          String?
  salary         Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}