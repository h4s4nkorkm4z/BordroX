{
  "appId": "com.bordrox.app",
  "productName": "BordroX",
  "asar": true,
  "directories": {
    "output": "release"
  },
  "files": [
    "dist",
    "dist-electron",
    "package.json"
  ],
  "win": {
  "icon": "public/bordrox.ico",
  "target": "nsis",
  "artifactName": "BordroX Setup ${version}.${ext}"
},
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "BordroX",
    "deleteAppDataOnUninstall": false
  }
}